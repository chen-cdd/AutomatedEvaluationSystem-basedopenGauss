APP_NAME=Agent Evaluation System
APP_ENV=development
API_V1_PREFIX=/api/v1
DATABASE_URL=sqlite:///./agent_eval.db
OPENGAUSS_URL=postgresql+psycopg2://gaussdb:password@localhost:5432/agent_eval
STORAGE_DIR=storage
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
JUDGE_MODEL_NAME=deepseek-v3
MAX_UPLOAD_SIZE_MB=10
MAX_CONCURRENT_JOBS=5
USE_MOCK_JUDGE=true
